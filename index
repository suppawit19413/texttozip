<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<title>HTML Generator</title>
<style>
  body { font-family: Arial, sans-serif; margin: 40px; max-width: 700px; }
  textarea { width: 100%; height: 200px; margin-bottom: 20px; }
  button { padding: 10px 20px; cursor: pointer; }
</style>
</head>
<body>
<h2>เครื่องมือสร้าง HTML</h2>
<p>วางข้อความที่ต้องการสร้างเป็น HTML แล้วกดสร้างไฟล์ ZIP:</p>
<textarea id="inputText" placeholder="วางข้อความของคุณที่นี่..."></textarea><br>
<button onclick="generateZip()">สร้างไฟล์ ZIP</button>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script>
function generateZip() {
    const JSZipInstance = new JSZip();
    const content = document.getElementById("inputText").value;

    const htmlContent = `
<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<title>หน้าเว็บของคุณ</title>
</head>
<body>
<div>
${content.replace(/\n/g, '<br>')}
</div>
</body>
</html>
    `.trim();

    JSZipInstance.file("index.html", htmlContent);

    JSZipInstance.generateAsync({type:"blob"}).then(function(content) {
        const link = document.createElement("a");
        link.href = URL.createObjectURL(content);
        link.download = "website.zip";
        link.click();
    });
}
</script>
</body>
</html>
